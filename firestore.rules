rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated admin
    function isAdmin() {
      return request.auth != null && request.auth.uid != null;
    }
    
    // Game state - Admin can write, everyone can read
    match /game_state/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Questions - Admin can write, everyone can read
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Users - Anyone can create/update their own user document
    // Admin can read/write all users
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth == null || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Answers - Users can create their own answers
    // Admin can read/write all answers
    // Users can only read their own answers
    match /answers/{answerId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
